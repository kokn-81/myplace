rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role check logic. We look up users collection or allow an initial admin email.
    function isAdmin() {
      return isSignedIn() && (
        // Allow the primary developer/user to act as admin based on email, or check db
        (request.auth.token.email == 'jhonny.a.coca.v@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        incoming().keys().hasAll(['userId', 'email', 'role']) &&
        incoming().userId == request.auth.uid &&
        (incoming().role == 'user' || isAdmin()); // users can only create 'user' roles initially unless they are admin
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'favorites', 'role']);
      allow delete: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /agents/{agentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
