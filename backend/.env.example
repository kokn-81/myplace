# Backend secrets. Copy this file to backend/.env and fill real values.

# Database
# Local fallback is SQLite when DATABASE_URL is empty.
# For production use a Postgres URL from Neon or Supabase.
DATABASE_URL=
AUTO_CREATE_TABLES=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Auth and roles
FIREBASE_PROJECT_ID=myplace-cc527
# Local: guarda el JSON descargado de Firebase en backend/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Produccion: puedes usar el JSON completo como variable secreta en vez de archivo
# FIREBASE_SERVICE_ACCOUNT_JSON={...}
ADMIN_EMAILS=tu_correo_admin@gmail.com
AUTHORIZED_ADVISOR_EMAILS=

# AI
GEMINI_API_KEY=tu_gemini_api_key

# Cloudinary signed uploads from backend
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=inmuebles

# Alternative: unsigned upload preset
# CLOUDINARY_UPLOAD_PRESET=tu_upload_preset_unsigned


